# Dev image for the API. Deps are baked in; the source is bind-mounted by
# docker-compose at runtime so `uvicorn --reload` picks up edits live. This is a
# development image — production self-host uses the multi-stage ../Dockerfile.
FROM python:3.12-slim
WORKDIR /app

# Install to system site-packages (no venv), which lives outside /app — so the
# compose bind mount of ./backend over /app doesn't shadow the dependencies.
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

EXPOSE 8000
# --reload-dir app keeps the watcher off tests/, .venv/, and other mounted noise.
CMD ["uvicorn", "app.main:app", "--reload", "--reload-dir", "app", \
     "--host", "0.0.0.0", "--port", "8000"]
