# Base URL of the Parsley API. Copy to `.env` (or set in the Vercel project) only
# when the frontend is hosted separately from the API.
#
# - Leave UNSET for local dev (Vite proxies /api to the backend) and for the
#   single-container Docker deploy (same origin) — the app calls relative /api/*.
# - SET to the API origin for the split Vercel deploy, e.g.
#     VITE_API_BASE=https://parsley-api.vercel.app
#
# It is baked in at build time, so changing it requires a frontend rebuild.
VITE_API_BASE=
